# ─────────────────────────────────────────────────────────────────────────
# RemnaShop — пример конфигурации.
#
# Если бот ещё не настроен — скопируйте файл (cp .env.example .env) и заполните
# раздел «ОБЯЗАТЕЛЬНО» + секреты бота.
#
# Если бот УЖЕ настроен и .env заполнен — просто запустите ./install.sh:
# он не тронет вашу конфигурацию, а лишь допишет недостающие переменные
# дополнения (раздел «Добавлено RemnaShop»: web/email), секреты сгенерирует сам.
# Полная документация по переменным:
#   https://remnashop.mintlify.app/docs/en/install/environment-variables
# ─────────────────────────────────────────────────────────────────────────


# ── ОБЯЗАТЕЛЬНО: ввести вручную ──────────────────────────────────────────

# Токен Telegram-бота от @BotFather. НИКОМУ не показывать.
BOT_TOKEN=
# Username бота без @ (нужен кабинету для Telegram-входа), напр. My_VPN_Bot
TELEGRAM_BOT_USERNAME=
# Ваш Telegram ID (числовой) — владелец с полными правами.
BOT_OWNER_ID=
# Username аккаунта поддержки без @ (для кнопки «Поддержка»).
BOT_SUPPORT_USERNAME=
# Домен бота БЕЗ http(s):// и БЕЗ слэша в конце (для вебхуков Telegram/платежей).
APP_DOMAIN=
# Публичный URL веб-кабинета (с https://). Используется и как разрешённый origin.
WEB_CABINET_URL=
APP_ORIGINS=
# Подключение к Remnawave API: хост/имя docker-сервиса и токен.
REMNAWAVE_HOST=remnawave
REMNAWAVE_TOKEN=


# ── СЕКРЕТЫ: сгенерировать (install.sh делает это сам) ────────────────────
# Вручную можно так:
#   APP_CRYPT_KEY:            openssl rand -base64 32
#   APP_JWT_SECRET/API_KEY:   openssl rand -hex 32
#   BOT_SECRET_TOKEN / *_WEBHOOK_SECRET: openssl rand -hex 64
#   DATABASE_PASSWORD:        openssl rand -hex 24
APP_CRYPT_KEY=
APP_JWT_SECRET=
APP_API_KEY=
BOT_SECRET_TOKEN=
REMNAWAVE_WEBHOOK_SECRET=
DATABASE_PASSWORD=


# ── РАЗУМНЫЕ ЗНАЧЕНИЯ ПО УМОЛЧАНИЮ ────────────────────────────────────────
WEB_ENABLED=true
# Поведение кнопки «Подключиться»: true — Mini App; см. документацию для URL.
BOT_MINI_APP=true
# Резервная кнопка (открыть в браузере), когда Mini App недоступен из-за блокировок.
BOT_MINI_APP_RESERVE=true


# ── EMAIL / SMTP (необязательно; нужно для регистрации по почте) ──────────
# EMAIL_ENABLED=false — регистрация только через Telegram.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=RemnaShop
# Brevo HTTP API key (xkeysib-…) — отправка писем в обход блокировок SMTP.
EMAIL_BREVO_API_KEY=


# ── Прочие опции с дефолтами (раскомментируйте при необходимости) ─────────
# APP_HOST=
# APP_PORT=
# APP_LOCALES=
# APP_DEFAULT_LOCALE=
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=
# DATABASE_USER=
# REDIS_HOST=
# REDIS_PORT=
# REDIS_PASSWORD=
# LOG_LEVEL=
# BOT_PROXY_URL=

# ── Вынос сайта (кабинета) на отдельный сервер ───────────────────────────
# По умолчанию кабинет работает на одном сервере с ботом и обе переменные не нужны.
#
# На сервере БОТА: на какой host-IP пробросить порт API (5000). По умолчанию
# 127.0.0.1 (только локально). Чтобы открыть API сайт-серверу через приватный
# канал (WireGuard/VPN) — впишите приватный IP бота, напр. WG-адрес.
# НЕ публичный IP без TLS/фаервола!
# API_BIND_HOST=127.0.0.1
#
# На сервере САЙТА (docker-compose.site.yml): адрес бэкенда бота host:port,
# куда nginx кабинета проксирует /api/. Напр. WG-адрес бота: 10.8.0.1:5000.
# API_UPSTREAM=
