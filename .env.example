# DATABASE_USER=
# DATABASE_ECHO=
# DATABASE_ECHO_POOL=
# DATABASE_POOL_SIZE=
# DATABASE_MAX_OVERFLOW=
# DATABASE_POOL_TIMEOUT=
# DATABASE_POOL_RECYCLE=

# LOG_TO_FILE=
# LOG_LEVEL=
# LOG_ROTATION=
# LOG_COMPRESSION=
# LOG_RETENTION=

# REDIS_HOST=
# REDIS_PORT=
# REDIS_NAME=
# REDIS_PASSWORD=

# REMNAWAVE_CADDY_TOKEN=
# REMNAWAVE_COOKIE=

# REMNAWAVE_CF_CLIENT_ID=
# REMNAWAVE_CF_CLIENT_SECRET=
TELEGRAM_BOT_USERNAME=
WEB_ENABLED=
APP_ORIGINS=
APP_API_KEY=
APP_JWT_SECRET=
WEB_CABINET_URL=

# Email / SMTP
EMAIL_ENABLED=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_USE_SSL=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=

# Brevo HTTP API key для отправки писем (обход блокировки SMTP). xkeysib-...
EMAIL_BREVO_API_KEY=
