# ─────────────────────────────────────────────────────────────────────────
# RemnaShop — пример конфигурации.
#
# Если бот ещё не настроен — скопируйте файл (cp .env.example .env) и заполните
# раздел «ОБЯЗАТЕЛЬНО» + секреты бота.
#
# Если бот УЖЕ настроен и .env заполнен — просто запустите ./install.sh:
# он не тронет вашу конфигурацию, а лишь допишет недостающие переменные
# дополнения (раздел «Добавлено RemnaShop»: web/email), секреты сгенерирует сам.
# Полная документация по переменным:
#   https://remnashop.mintlify.app/docs/en/install/environment-variables
# ─────────────────────────────────────────────────────────────────────────


# ── ОБЯЗАТЕЛЬНО: ввести вручную ──────────────────────────────────────────

# Токен Telegram-бота от @BotFather. НИКОМУ не показывать.
BOT_TOKEN=
# Username бота без @ (нужен кабинету для Telegram-входа), напр. My_VPN_Bot
TELEGRAM_BOT_USERNAME=
# Ваш Telegram ID (числовой) — владелец с полными правами.
BOT_OWNER_ID=
# Username аккаунта поддержки без @ (для кнопки «Поддержка»).
BOT_SUPPORT_USERNAME=
# Домен бота БЕЗ http(s):// и БЕЗ слэша в конце (для вебхуков Telegram/платежей).
APP_DOMAIN=
# Публичный URL веб-кабинета (с https://). Используется и как разрешённый origin.
WEB_CABINET_URL=
APP_ORIGINS=
# (Необязательно) Вход в кабинет через Telegram по OpenID Connect — новый флоу.
# Если пусто — кабинет показывает классический Telegram Login Widget (как раньше).
# Значения выдаёт @BotFather → Bot Settings → Web Login, туда же добавьте в
# Allowed URLs адрес: https://<домен_кабинета>/api/auth/telegram/oidc/callback
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
# Подключение к Remnawave API: хост/имя docker-сервиса и токен.
REMNAWAVE_HOST=remnawave
REMNAWAVE_TOKEN=


# ── СЕКРЕТЫ: сгенерировать (install.sh делает это сам) ────────────────────
# Вручную можно так:
#   APP_CRYPT_KEY:            openssl rand -base64 32
#   APP_JWT_SECRET/API_KEY:   openssl rand -hex 32
#   BOT_SECRET_TOKEN / *_WEBHOOK_SECRET: openssl rand -hex 64
#   DATABASE_PASSWORD:        openssl rand -hex 24
APP_CRYPT_KEY=
APP_JWT_SECRET=
APP_API_KEY=
BOT_SECRET_TOKEN=
REMNAWAVE_WEBHOOK_SECRET=
DATABASE_PASSWORD=


# ── РАЗУМНЫЕ ЗНАЧЕНИЯ ПО УМОЛЧАНИЮ ────────────────────────────────────────
WEB_ENABLED=true
# Поведение кнопки «Подключиться»: true — Mini App; см. документацию для URL.
BOT_MINI_APP=true
# Резервная кнопка (открыть в браузере), когда Mini App недоступен из-за блокировок.
BOT_MINI_APP_RESERVE=true
# Состав кнопок доступа в главном меню (когда WEB_ENABLED=true). Каждую можно
# включить/выключить. Дефолт: кабинет в Mini App + кабинет в браузере + сабка.
BOT_MENU_CABINET_MINIAPP=true   # «Личный кабинет» через Mini App
BOT_MENU_CABINET_URL=true       # «Кабинет в браузере» — прямая ссылка на сайт
BOT_MENU_CONNECT_MINIAPP=false  # «Подключиться» → кабинет /devices в Mini App
BOT_MENU_CONNECT_URL=false      # «Подключиться» → кабинет /devices прямой ссылкой
BOT_MENU_REMNA_SUB=true         # «Подписка (резерв)» — стандартная сабка Remnawave
# Уведомлять владельца (BOT_OWNER_ID) в Telegram о новой версии форка (раз в день).
UPDATE_NOTIFY=true


# ── EMAIL / SMTP (необязательно; нужно для регистрации по почте) ──────────
# EMAIL_ENABLED=false — регистрация только через Telegram.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=RemnaShop
# Brevo HTTP API key (xkeysib-…) — отправка писем в обход блокировок SMTP.
EMAIL_BREVO_API_KEY=


# ── Прочие опции с дефолтами (раскомментируйте при необходимости) ─────────
# APP_HOST=
# APP_PORT=
# APP_LOCALES=
# APP_DEFAULT_LOCALE=
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=
# DATABASE_USER=
# REDIS_HOST=
# REDIS_PORT=
# REDIS_PASSWORD=
# LOG_LEVEL=
# BOT_PROXY_URL=

# ── Вынос сайта (кабинета) на отдельный сервер ───────────────────────────
# По умолчанию кабинет работает на одном сервере с ботом и эти переменные не нужны.
#
# На отдельном сервере кабинет проксирует /api/ на ПУБЛИЧНЫЙ API бота по https
# (его уже отдаёт reverse-proxy бота на его домене) — приватный канал/WG не нужен.
# Эти переменные ставит сам ./install.sh site; править вручную обычно не требуется:
#   API_UPSTREAM=bot.example.com:443     # домен API бота : 443
#   API_SCHEME=https                     # http для co-located, https для отдельного
#   API_HOST_HEADER=bot.example.com      # Host/SNI, по которому reverse-proxy бота
#                                        # маршрутизирует запрос (для co-located = $host)
